#!/bin/sh

DIVIDER="------------------------------------------------------------------------------"

# Redirect output to stderr.
exec 1>&2
# enable user input
exec < /dev/tty

# Check if on a protected branch (main or master). Stop accidental commits.
current_branch=$(git symbolic-ref HEAD 2>/dev/null)
if [ "$current_branch" = "refs/heads/main" ] || [ "$current_branch" = "refs/heads/master" ]; then
  branch_name="${current_branch##refs/heads/}"
  echo "$DIVIDER"
  echo "WARNING: You are about to commit to the $branch_name branch."
  echo "$DIVIDER"
  read -p "Are you sure you want to continue? (y/n) " response
  if ! echo "$response" | grep -q '^[Yy]$'; then
    exit 1
  fi
fi

# Check for console.log statements in staged changes
if git diff --cached | grep -q 'console\.log'; then
  echo "$DIVIDER"
  echo "WARNING: Found console.log statements in staged changes:"
  echo "$DIVIDER"
  git diff --cached | grep -n 'console\.log'
  echo ""
  read -p "Continue with commit? (y/n) " response
  if ! echo "$response" | grep -q '^[Yy]$'; then
    exit 1
  fi
fi

# Check for debugger statements in staged changes
if git diff --cached | grep -q 'debugger'; then
  echo "$DIVIDER"
  echo "WARNING: Found debugger statements in staged changes:"
  echo "$DIVIDER"
  git diff --cached | grep -n 'debugger'
  echo ""
  read -p "Continue with commit? (y/n) " response
  if ! echo "$response" | grep -q '^[Yy]$'; then
    exit 1
  fi
fi

exit 0
